# Copy to .env before running docker-compose up.
#
# docker-compose.yml reads POSTGRES_DB, POSTGRES_USER, and POSTGRES_PASSWORD
# from this file to configure the db service and to build the app's
# DATABASE_URL. DATABASE_URL below is NOT read by docker-compose; it's only
# used when running run.py directly (outside docker-compose), e.g. against a
# local or managed Postgres instance.

POSTGRES_DB=canals
POSTGRES_USER=canals
POSTGRES_PASSWORD=canals_dev_password

DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_STATEMENT_TIMEOUT_MS=30000
PORT=8000
